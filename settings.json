{
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet"
  },
  "permissions": {
    "deny": [
      "Bash(sudo *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)"
    ],
    "allow": [
      "mcp__plugin_serena_serena",
      "mcp__sequential-thinking",
      "Bash(eza *)",
      "Bash(bat *)",
      "Bash(fd *)",
      "Bash(rg *)",
      "Bash(dust *)",
      "Bash(duf *)",
      "Bash(tokei *)",
      "Bash(jj *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git status *)",
      "Bash(task *)",
      "Bash(jq *)",
      "Bash(ruff *)",
      "Bash(ty *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)"
    ]
  },
  "model": "opusplan",
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7-plugin@context7-marketplace": true,
    "serena@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    },
    "claude-code-workflows": {
      "source": {
        "source": "github",
        "repo": "wshobson/agents"
      }
    },
    "everything-claude-code": {
      "source": {
        "source": "github",
        "repo": "affaan-m/everything-claude-code"
      }
    },
    "repomix": {
      "source": {
        "source": "github",
        "repo": "yamadashy/repomix"
      }
    },
    "awesome-claude-skills": {
      "source": {
        "source": "github",
        "repo": "ComposioHQ/awesome-claude-skills"
      }
    },
    "chrome-devtools-plugins": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      }
    },
    "context-engineering-marketplace": {
      "source": {
        "source": "github",
        "repo": "muratcankoylan/Agent-Skills-for-Context-Engineering"
      }
    },
    "claude-scientific-skills": {
      "source": {
        "source": "github",
        "repo": "K-Dense-AI/claude-scientific-skills"
      }
    },
    "context7-marketplace": {
      "source": {
        "source": "github",
        "repo": "upstash/context7"
      }
    }
  },
  "language": "Japanese",
  "alwaysThinkingEnabled": false,
  "effortLevel": "medium",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
