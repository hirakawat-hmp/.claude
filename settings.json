{
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet"
  },
  "permissions": {
    "allow": [
      "mcp__plugin_serena_serena",
      "mcp__sequential-thinking",
      "Bash(eza *)",
      "Bash(bat *)",
      "Bash(fd *)",
      "Bash(rg *)",
      "Bash(dust *)",
      "Bash(duf *)",
      "Bash(tokei *)",
      "Bash(jj *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git status *)",
      "Bash(task *)",
      "Bash(jq *)",
      "Bash(ruff *)",
      "Bash(ty *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(xh *)",
      "Bash(source *)",
      "Read(~/.claude/skills/kie-ai/.env)",
      "mcp__pencil"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/hdymacuser/.claude/hooks/session-start.sh",
            "timeout": 15,
            "statusMessage": "Loading project state..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7-plugin@context7-marketplace": true,
    "serena@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "drawio@365-skills": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "document-skills@anthropic-agent-skills": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    },
    "claude-code-workflows": {
      "source": {
        "source": "github",
        "repo": "wshobson/agents"
      }
    },
    "everything-claude-code": {
      "source": {
        "source": "github",
        "repo": "affaan-m/everything-claude-code"
      }
    },
    "repomix": {
      "source": {
        "source": "github",
        "repo": "yamadashy/repomix"
      }
    },
    "awesome-claude-skills": {
      "source": {
        "source": "github",
        "repo": "ComposioHQ/awesome-claude-skills"
      }
    },
    "chrome-devtools-plugins": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      }
    },
    "context-engineering-marketplace": {
      "source": {
        "source": "github",
        "repo": "muratcankoylan/Agent-Skills-for-Context-Engineering"
      }
    },
    "claude-scientific-skills": {
      "source": {
        "source": "github",
        "repo": "K-Dense-AI/claude-scientific-skills"
      }
    },
    "context7-marketplace": {
      "source": {
        "source": "github",
        "repo": "upstash/context7"
      }
    },
    "365-skills": {
      "source": {
        "source": "github",
        "repo": "Agents365-ai/365-skills"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "language": "Japanese",
  "alwaysThinkingEnabled": false,
  "effortLevel": "medium",
  "tui": "fullscreen",
  "autoCompactEnabled": true,
  "remoteControlAtStartup": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
